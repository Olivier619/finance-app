# Configuration des API Keys (copier ce fichier en .env et remplir les valeurs)

# NewsAPI (gratuit sur https://newsapi.org/)
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage (gratuit sur https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# Finnhub (gratuit sur https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_key_here

# Configuration SMTP pour les alertes email
# Pour Gmail: smtp.gmail.com, port 587
# Activer "Autoriser les applications moins sécurisées" ou utiliser un mot de passe d'application
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL=your_email@gmail.com
